# Если стоит то make воспринимает команду как для разработки (необязательно) , prod, local может быть такие значения
STAGE=develop
# !Токен Telegram-бота
BOT_TOKEN=your_bot_token_here
#Настроки сервера на которм контейнер с VPN для подключения к нему.
VPN_HOST=177.177.177.1
VPN_USERNAME=username
VPN_CONTAINER=amnezia-awg
VPN_PROXY=amnezia-socks5proxy
PROXY_PORT=8443
MAX_CONFIGS_PER_USER=10
# !Список ID администраторов в формате строки списка
ADMIN_IDS='[123456789]'
# Цена за тарифы 1,3,6,12 месяцев и триал период
PRICE_MAP={"1":70,"3":160,"6":300,"12":600,"14":0}
# !Базовый URL сайта (например, для webhook)
BASE_SITE=https://your-domain.com
# *Настройки FastAPI
DEBUG_FAST_API=True
RELOAD_FAST_API=True
# *Уровни логирования
LOGGER_LEVEL_STDOUT=DEBUG
LOGGER_LEVEL_FILE=DEBUG
LOGGER_ERROR_FILE=WARNING
# * Настройки базы данных PostgreSQL
DB_HOST=localhost
#DB_HOST=db
DB_PORT=5432
# !Обязательно
DB_USER=your_user
DB_PASSWORD=your_password
DB_DATABASE=your_database
# *Контекнер Redis
REDIS_HOST=localhost
#REDIS_HOST=redis
REDIS_PORT=6379
NUM_DB=0
DEFAULT_EXPIRE=3600
# !Обязательно
REDIS_USER=your_user
REDIS_PASSWORD=your_redis_password
# *Использовать webhook или polling
USE_POLLING=True
# Если бот и ВПН на одном сервере True
USE_LOCAL=True
#Bucket настройки
BUCKET_NAME=vpn-bot-images
PREFIX=media/
ENDPOINT_URL=https://storage.yandexcloud.net
ACCESS_KEY=your_key
SECRET_KEY=your_key
#AI модель указвать только на локальной разработке так все через яндекс идет
ACCESS_KEY_AI=your_key
SECRET_KEY_AI=your_key
YANDEX_FOLDER_ID=your_key
MODEL_LLM_NAME=intfloat/multilingual-e5-base
NORMALIZE=True
# При инициализации на проде не нужно скачивать тяжелые бибилотеки тоьлко для локальной разработки
SKIP_AI_INIT=True
#SESSION для админки ключ.
SESSION_SECRET=key
