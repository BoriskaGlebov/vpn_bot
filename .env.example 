STAGE=develop
# !Токен Telegram-бота
BOT_TOKEN=your_bot_token_here
#Настроки сервера на которм контейнер с VPN для подключения к нему.
#Дефолтное время для Timeout ошибки при подключени к стороннему сревису
COMMON_TIMEOUT=10
VPN_HOST=177.177.177.1
VPN_USERNAME=username
VPN_CONTAINER=amnezia-awg
#Важная настройка так как прокси я делаю на поддомене
PROXY_PREFIX=proxy-boriska
