# *Контекнер Redis по умолчанию redis
REDIS_HOST=localhost
#REDIS_HOST=redis
# по умолчанию порт 6379
REDIS_PORT=6379
# по умолачанию пишит все в 0 базу
NUM_DB=0
# по умолчанию 3600 секунд время жизни кэша редис
DEFAULT_EXPIRE=3600
# !Обязательно
REDIS_USER=your_user
REDIS_PASSWORD=your_redis_password
# *Использовать webhook или polling по умолчанию polling false
USE_POLLING=True
# Если бот и ВПН на одном сервере True
USE_LOCAL=True
#Bucket настройки
BUCKET_NAME=vpn-bot-images
PREFIX=media/
ENDPOINT_URL=https://storage.yandexcloud.net
ACCESS_KEY=your_key
SECRET_KEY=your_key
#AI модель указвать только на локальной разработке так все через яндекс идет
SECRET_KEY_AI=your_key
YANDEX_FOLDER_ID=your_key
#Размерность для эмбеддингов 256 такую LLM нало брать, что б в БД положить
MODEL_LLM_NAME=intfloat/multilingual-e5-base
#Размерность для эмбеддингов по умолчанию Яндекс использует 256  и на локльно модели тот же парметр
EMBEDDING_DIM=256

#по умослчани нормализация TRUE
NORMALIZE=True
# При инициализации на проде не нужно скачивать тяжелые бибилотеки тоьлко для локальной разработки
