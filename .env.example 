PRICE_MAP={"1":70,"3":160,"6":300,"12":600,"7":0}
# !Базовый URL сайта (например, для webhook)
BASE_SITE=https://your-domain.com
# *Настройки FastAPI по умолчани юоба False
DEBUG_FAST_API=True
RELOAD_FAST_API=True
# *Уровни логирования по умолчанию INFO INFO WARNING
LOGGER_LEVEL_STDOUT=DEBUG
LOGGER_LEVEL_FILE=DEBUG
LOGGER_ERROR_FILE=WARNING
# * Настройки базы данных PostgreSQL по умолчанию postgres
DB_HOST=localhost
#DB_HOST=db
# по умолчани порт 5432
DB_PORT=5432
# !Обязательно
DB_USER=your_user
DB_PASSWORD=your_password
